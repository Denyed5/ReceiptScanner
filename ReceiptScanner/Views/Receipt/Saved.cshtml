@{
    ViewData["Title"] = "Запазено";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6 text-center">
                <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">
                    <div class="badge bg-success mb-3">Запазено</div>

                    <h1 class="h2 fw-bold mb-3">
                        Касовата бележка беше запазена успешно
                    </h1>

                    <p class="text-muted mb-4">
                        Извлечената информация от касовата бележка беше запазена във вашия акаунт.
                    </p>

                    <div class="d-grid d-sm-flex justify-content-sm-center gap-2">
                        <a asp-controller="Receipt"
                           asp-action="Upload"
                           class="btn btn-primary btn-lg">
                            Сканирай друга касова бележка
                        </a>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline-secondary btn-lg">
                            Обратно към началната страница
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>