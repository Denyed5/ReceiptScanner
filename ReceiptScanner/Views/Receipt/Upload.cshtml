@model ReceiptUploadModel

@{
    ViewData["Title"] = "Добавяне на касова бележка";
}

<section class="py-4 py-lg-4">
    <div class="container">
            <div class="row">
                <div class="col-12">
                <div class="dashboard-header mb-3">
                    <div>
                        <h1 class="mb-2">Добавяне на касова бележка</h1>
                        <p class="mb-0">
                            Направи снимка на касова бележка или добави съществуващо изображение, след което я сканирай чрез OCR.
                        </p>
                    </div>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Dashboard"
                        asp-action="Dashboard"
                        class="btn btn-primary btn-lg">
                            Назад към таблото
                        </a>
                    }
                </div>

                <form id="uploadForm" asp-controller="Receipt" asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="croppedImage" id="croppedImage" />
                    <input type="hidden" id="uploadInitialErrorMessage" value="@ViewBag.UploadErrorMessage" />

                    <div class="row g-4">
                        <div class="col-12 col-lg-7">
                            <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">
                                <label class="form-label fw-semibold">
                                    Изображение на касова бележка (.jpg, .jpeg, .png, .bmp)
                                </label>

                                <div class="d-grid d-sm-flex gap-2 mb-3">
                                    <button class="btn btn-primary" type="button" id="takePhotoBtn">
                                        Направи снимка
                                    </button>

                                    <button class="btn btn-outline-primary" type="button" id="chooseFileBtn">
                                        Избери изображение
                                    </button>
                                </div>

                                <input name="File" id="cameraInput" class="visually-hidden" type="file" accept="image/*" capture="environment" />
                                <input name="File" id="receiptInput" class="visually-hidden" type="file" accept="image/*" />

                                <span asp-validation-for="File" class="text-danger small"></span>

                                <div class="mt-3 border rounded-3 bg-light overflow-hidden">
                                    <div class="crop-container d-flex align-items-center justify-content-center">
                                        <img id="image" class="img-fluid" alt="" />
                                        <div id="emptyPreview" class="text-muted text-center p-5">
                                            Направи снимка или избери изображение на касова бележка, за да го прегледаш и изрежеш тук.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-5">
                            <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">
                                <h2 class="h5 fw-semibold mb-3">OCR език</h2>

                                <div class="vstack gap-2">
                                    <label class="border rounded-3 p-3 d-flex gap-2">
                                        <input class="form-check-input mt-1" type="radio" name="Language" value="bul+eng" checked>
                                        <span>
                                            <span class="d-block fw-semibold">Български и английски</span>
                                            <span class="d-block text-muted small">Най-добрият избор за смесени касови бележки.</span>
                                        </span>
                                    </label>

                                    <label class="border rounded-3 p-3 d-flex gap-2">
                                        <input class="form-check-input mt-1" type="radio" name="Language" value="bul">
                                        <span>
                                            <span class="d-block fw-semibold">Български</span>
                                            <span class="d-block text-muted small">Използвай за касови бележки само на български.</span>
                                        </span>
                                    </label>

                                    <label class="border rounded-3 p-3 d-flex gap-2">
                                        <input class="form-check-input mt-1" type="radio" name="Language" value="eng">
                                        <span>
                                            <span class="d-block fw-semibold">Английски</span>
                                            <span class="d-block text-muted small">Използвай за касови бележки само на английски.</span>
                                        </span>
                                    </label>
                                </div>

                                <div class="form-check form-switch mt-4">
                                    <input class="form-check-input" asp-for="UsePreprocessing" type="checkbox" />
                                    <label class="form-check-label" asp-for="UsePreprocessing">
                                        Допълнителна обработка на изображението
                                    </label>
                                </div>

                                <button class="btn btn-success btn-lg w-100 mt-4" id="scanBtn" type="button">
                                    Сканирай касова бележка
                                </button>

                                @if (ViewBag.Message != null)
                                {
                                    <div class="alert alert-info mt-3 mb-0">
                                        @ViewBag.Message
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="uploadErrorModal" tabindex="-1" aria-labelledby="uploadErrorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="uploadErrorModalLabel">Грешка при добавяне на изображение</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body" id="uploadErrorMessage">
                Неподдържан формат на изображението. Моля, избери JPG, PNG или BMP изображение на касова бележка.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">
                    Избери друго изображение
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/receipt-upload.js" asp-append-version="true"></script>
}