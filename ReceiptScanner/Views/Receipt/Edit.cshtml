@model ReceiptScanner.Models.ReceiptModel

@{
    ViewData["Title"] = "Редактиране на касова бележка";
}

<section class="py-4 py-lg-4">
    <div class="container">
        @using (Html.BeginForm("Edit", "Receipt", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input asp-for="ReceiptId" type="hidden" />
            <input asp-for="RawText" type="hidden" />

            <div class="dashboard-header mb-3 mb-4">
                <div>
                    <h1 class="mb-2">Редактиране на касова бележка</h1>
                    <p class="mb-0">
                        Актуализирай запазеното обобщение и списъка с продукти.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-end pb-1">
                    <button type="submit"
                            class="btn btn-primary px-3 py-2">
                        Запази промените
                    </button>

                    <a asp-controller="Receipt"
                       asp-action="Details"
                       asp-route-id="@Model.ReceiptId"
                       class="btn btn-primary px-3 py-2">
                        Отказ
                    </a>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-4">
                <div class="col-12 col-lg-4">
                    <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">
                        <h2 class="h5 fw-semibold mb-3">Обобщение на касовата бележка</h2>

                        <div class="mb-3">
                            <label asp-for="VendorName" class="form-label">Търговец</label>
                            <input asp-for="VendorName" class="form-control" />
                            <span asp-validation-for="VendorName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Date" class="form-label">Дата</label>
                            <input asp-for="Date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TotalBGN" class="form-label">Общо в лева</label>
                            <input asp-for="TotalBGN" class="form-control" />
                            <span asp-validation-for="TotalBGN" class="text-danger small"></span>
                        </div>

                        <div class="mb-0">
                            <label asp-for="TotalEUR" class="form-label">Общо в евро</label>
                            <input asp-for="TotalEUR" class="form-control" />
                            <span asp-validation-for="TotalEUR" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-8">
                    <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">
                        <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 mb-3">
                            <div>
                                <h2 class="h5 fw-semibold mb-1">Закупени продукти</h2>
                                <p class="text-muted small mb-0">
                                    Добавяй, премахвай или коригирай запазените продукти.
                                </p>
                            </div>

                            <button id="addItemBtn"
                                    type="button"
                                    class="btn btn-outline-primary">
                                Добави продукт
                            </button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0 receipt-items-table" id="itemsTable">
                                <colgroup>
                                    <col class="item-name-col" />
                                    <col class="item-quantity-col" />
                                    <col class="item-price-col" />
                                    <col class="item-price-col" />
                                    <col class="item-category-col" />
                                    <col class="item-action-col" />
                                </colgroup>

                                <thead>
                                    <tr>
                                        <th>Продукт</th>
                                        <th>Количество</th>
                                        <th>Ед. цена</th>
                                        <th>Общо</th>
                                        <th>Категория</th>
                                        <th class="text-end">Действие</th>
                                    </tr>
                                </thead>

                                <tbody id="itemsBody">
                                    @for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr class="receipt-item-row">
                                            <td data-label="Продукт">
                                                <input type="hidden" asp-for="Items[i].ItemId" />
                                                <input type="hidden" asp-for="Items[i].ReceiptId" />
                                                <input asp-for="Items[i].Name" class="form-control item-name" />
                                            </td>

                                            <td data-label="Количество">
                                                <input asp-for="Items[i].Quantity" class="form-control item-quantity" />
                                            </td>

                                            <td data-label="Ед. цена">
                                                <input asp-for="Items[i].UnitPrice" class="form-control item-unit-price" />
                                            </td>

                                            <td data-label="Общо">
                                                <input asp-for="Items[i].TotalPrice" class="form-control item-total-price" />
                                            </td>

                                            <td data-label="Категория">
                                                <select asp-for="Items[i].CategoryId"
                                                        class="form-select item-category"
                                                        asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "Name"))">
                                                    <option value="">Избери категория</option>
                                                </select>
                                            </td>

                                            <td data-label="Действие" class="text-end">
                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm remove-item-btn"
                                                        aria-label="Премахни продукт"
                                                        title="Премахни продукт">
                                                    &times;
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div id="emptyItemsMessage"
                             class="alert alert-warning mt-3 mb-0 @(Model.Items.Count > 0 ? "d-none" : "")">
                            В момента няма добавени продукти. При нужда добави продукт ръчно.
                        </div>
                        <div class="d-grid d-md-flex justify-content-md-end gap-2 mt-4">
                            <a asp-controller="Receipt"
                               asp-action="Details"
                               asp-route-id="@Model.ReceiptId"
                               class="btn btn-outline-secondary btn-lg">
                                Отказ
                            </a>

                            <button type="submit" class="btn btn-success btn-lg">
                                Запази промените
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<template id="itemRowTemplate">
    <tr class="receipt-item-row">
        <td data-label="Продукт">
            <input type="hidden" data-field="ItemId" value="" />
            <input type="hidden" data-field="ReceiptId" value="" />
            <input data-field="Name" class="form-control item-name" value="" />
        </td>

        <td data-label="Количество">
            <input data-field="Quantity" class="form-control item-quantity" value="1" />
        </td>

        <td data-label="Ед. цена">
            <input data-field="UnitPrice" class="form-control item-unit-price" value="0.00" />
        </td>

        <td data-label="Общо">
            <input data-field="TotalPrice" class="form-control item-total-price" value="0.00" />
        </td>

        <td data-label="Категория">
            <select data-field="CategoryId" class="form-select item-category">
                <option value="">Избери категория</option>

                @foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.CategoryId">@category.Name</option>
                }
            </select>
        </td>

        <td data-label="Действие" class="text-end">
            <button type="button"
                    class="btn btn-outline-danger btn-sm remove-item-btn"
                    aria-label="Премахни продукт"
                    title="Премахни продукт">
                &times;
            </button>
        </td>
    </tr>
</template>

<div class="modal fade" id="totalMismatchModal" tabindex="-1" aria-labelledby="totalMismatchModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="totalMismatchModalLabel">
                    Несъответствие в сумите
                </h2>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Затвори">
                </button>
            </div>

            <div class="modal-body">
                <p>
                    Общата сума в евро не съвпада със сумата на продуктите.
                </p>

                <div class="vstack gap-2">
                    <div>
                        Общо в евро:
                        <strong id="receiptTotalEurText">0.00</strong>
                    </div>

                    <div>
                        Сума на продуктите:
                        <strong id="itemsTotalEurText">0.00</strong>
                    </div>

                    <div>
                        Разлика:
                        <strong id="totalDifferenceEurText">0.00</strong>
                    </div>
                </div>

                <p class="mb-0 mt-3 text-muted">
                    Искаш ли да запазиш касовата бележка въпреки разликата?
                </p>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Отказ
                </button>

                <button type="button"
                        class="btn btn-warning"
                        id="confirmMismatchSaveBtn">
                    Запази въпреки това
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/receipt-result.js" asp-append-version="true"></script>
}
