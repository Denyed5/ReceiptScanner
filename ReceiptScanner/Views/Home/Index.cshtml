@{
    ViewData["Title"] = "Начало";
}

<section class="landing-hero landing-hero-compact" style="background-image: url('@Url.Content("~/images/landing-hero-receipt-scanner.png")');">
    <div class="landing-hero-overlay">
        <div class="container">
            <div class="landing-hero-content">

                <h1 class="landing-title">
                    От снимка на касова бележка, до категоризиран разход.
                </h1>

                <p class="landing-subtitle">
                    Добави касова бележка, провери извлечените продукти и запази разходите си по категории, в евро и лева.
                </p>

                <div class="landing-actions">
                    <a asp-controller="Receipt" asp-action="Upload" class="btn btn-success btn-lg">
                        Изпробвай
                    </a>

                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg">
                        Регистрация
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="landing-section landing-summary-strip">
    <div class="container">
        <div class="landing-summary-grid">
            <div>
                <span>Автоматично извличане на текст</span>
                <strong>OCR извлича автоматично текста, без да се налага да пишеш всичко от нулата.</strong>
            </div>

            <div>
                <span>Редакция</span>
                <strong>Възможност за редакция преди и след запазване на касова бележка.</strong>
            </div>

            <div>
                <span>Проследяване на разходи</span>
                <strong>Проследяване на разходи, разпределени по категории и месеци.</strong>
            </div>
        </div>
    </div>
</section>

<section class="landing-section landing-preview-section">
    <div class="container">
        <div class="row align-items-center g-4">
                <div class="col-12 col-lg-4">
                <span class="landing-section-kicker">Табло</span>
                <h2 class="landing-section-title">Проследяваш разходите си, без да събираш касови бележки.</h2>
                <p class="landing-muted">
                    Последните бележки, общите разходи и категориите са събрани на едно място.
                </p>

                <a asp-controller="Dashboard" asp-action="Dashboard" class="btn btn-outline-primary btn-lg">
                    Отвори таблото
                </a>
                </div>

                <div class="col-12 col-lg-8">
                <div class="landing-dashboard-preview">
                    <img src="~/images/landing-dashboard.png"
                         class="landing-dashboard-image"
                         alt="Примерен изглед на таблото с разходи" />
                </div>
            </div>
        </div>
    </div>
</section>

    <section class="landing-section landing-preview-section">
        <div class="container">
            <div class="row align-items-center g-4">

                <div class="col-12 col-lg-8">
                    <div class="landing-dashboard-preview">
                        <img src="~/images/landing_analitycs.png"
                             class="landing-dashboard-image"
                             alt="Примерен изглед на таблото с разходи" />
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <span class="landing-section-kicker">Анализ</span>
                    <h2 class="landing-section-title">Всички данни изобразени в графичен вид.</h2>
                    <p class="landing-muted">
                        Анализ на данните представен в графичен вид.
                    </p>

                    <a asp-controller="Dashboard" asp-action="Analytics" class="btn btn-outline-primary btn-lg">
                        Анализи
                    </a>
                </div>
            </div>
        </div>
    </section>

<section class="landing-section landing-final-cta">
    <div class="container">
        <div class="landing-final-content">
            <div>
                <h2>Добави първата си бележка и виж резултата.</h2>
            </div>

            <div class="landing-final-actions">
                <a asp-controller="Receipt" asp-action="Upload" class="btn btn-primary btn-lg">
                    Изпробвай
                </a>

                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg">
                    Регистрация
                </a>
            </div>
        </div>
    </div>
</section>
