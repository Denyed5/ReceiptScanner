@{
    ViewData["Title"] = "Privacy";
}

<section class="py-4 py-lg-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <h1 class="h2 fw-bold mb-3">Privacy</h1>
                <p class="text-muted mb-4">
                    ReceiptScanner processes receipt images and extracted expense data in order to provide OCR scanning, storage, and spending analysis features.
                </p>

                <div class="vstack gap-3">
                    <div class="border rounded-3 p-3 p-md-4">
                        <h2 class="h5 fw-semibold">Uploaded receipts</h2>
                        <p class="text-muted mb-0">
                            Receipt images are used for text extraction. The extracted result may include vendor names, dates, totals, products, and categories.
                        </p>
                    </div>

                    <div class="border rounded-3 p-3 p-md-4">
                        <h2 class="h5 fw-semibold">User data</h2>
                        <p class="text-muted mb-0">
                            Saved receipts are connected to the logged-in user account so each user can access their own receipt history.
                        </p>
                    </div>

                    <div class="border rounded-3 p-3 p-md-4">
                        <h2 class="h5 fw-semibold">Analytics</h2>
                        <p class="text-muted mb-0">
                            Expense summaries and charts are generated from saved receipt data such as totals, categories, and dates.
                        </p>
                    </div>

                    <div class="border rounded-3 p-3 p-md-4">
                        <h2 class="h5 fw-semibold">Project note</h2>
                        <p class="text-muted mb-0">
                            This page is a project placeholder and can be expanded with a complete privacy policy if the application is published for real users.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
