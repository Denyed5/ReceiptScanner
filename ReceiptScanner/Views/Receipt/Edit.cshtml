@model ReceiptScanner.Models.ReceiptModel

@{
    ViewData["Title"] = "Edit Receipt";
}

<section class="py-4 py-lg-5">
    <div class="container">
        @using (Html.BeginForm("Edit", "Receipt", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input asp-for="ReceiptId" type="hidden" />
            <input asp-for="RawText" type="hidden" />

            <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                <div>
                    <h1 class="h2 fw-bold mb-2">Edit receipt</h1>
                    <p class="text-muted mb-0">
                        Update the saved receipt summary and item list.
                    </p>
                </div>

                <div class="d-grid d-md-flex gap-2">
                    <a asp-controller="Receipt" asp-action="Details" asp-route-id="@Model.ReceiptId" class="btn btn-outline-secondary btn-lg">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-success btn-lg">
                        Save changes
                    </button>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-4">
                <div class="col-12 col-lg-4">
                    <div class="border rounded-3 p-3 p-md-4 h-100">
                        <h2 class="h5 fw-semibold mb-3">Receipt summary</h2>

                        <div class="mb-3">
                            <label asp-for="VendorName" class="form-label">Vendor</label>
                            <input asp-for="VendorName" class="form-control" />
                            <span asp-validation-for="VendorName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Date" class="form-label">Date</label>
                            <input asp-for="Date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TotalBGN" class="form-label">Total in BGN</label>
                            <input asp-for="TotalBGN" class="form-control" />
                            <span asp-validation-for="TotalBGN" class="text-danger small"></span>
                        </div>

                        <div class="mb-0">
                            <label asp-for="TotalEUR" class="form-label">Total in EUR</label>
                            <input asp-for="TotalEUR" class="form-control" />
                            <span asp-validation-for="TotalEUR" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-8">
                    <div class="border rounded-3 p-3 p-md-4 h-100">
                        <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 mb-3">
                            <div>
                                <h2 class="h5 fw-semibold mb-1">Purchased items</h2>
                                <p class="text-muted small mb-0">Add, remove, or correct saved receipt items.</p>
                            </div>

                            <button id="addItemBtn" type="button" class="btn btn-outline-primary">
                                Add item
                            </button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0 receipt-items-table" id="itemsTable">
                                <colgroup>
                                    <col class="item-name-col" />
                                    <col class="item-quantity-col" />
                                    <col class="item-price-col" />
                                    <col class="item-price-col" />
                                    <col class="item-category-col" />
                                    <col class="item-action-col" />
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Qty</th>
                                        <th>Unit price</th>
                                        <th>Total</th>
                                        <th>Category</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>

                                <tbody id="itemsBody">
                                    @for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr class="receipt-item-row">
                                            <td data-label="Product">
                                                <input type="hidden" asp-for="Items[i].ItemId" />
                                                <input type="hidden" asp-for="Items[i].ReceiptId" />
                                                <input asp-for="Items[i].Name" class="form-control item-name" />
                                            </td>
                                            <td data-label="Qty">
                                                <input asp-for="Items[i].Quantity" class="form-control item-quantity" />
                                            </td>
                                            <td data-label="Unit price">
                                                <input asp-for="Items[i].UnitPrice" class="form-control item-unit-price" />
                                            </td>
                                            <td data-label="Total">
                                                <input asp-for="Items[i].TotalPrice" class="form-control item-total-price" />
                                            </td>
                                            <td data-label="Category">
                                                <input asp-for="Items[i].Category" class="form-control item-category" />
                                            </td>
                                            <td data-label="Action" class="text-end">
                                                <button type="button" class="btn btn-outline-danger btn-sm remove-item-btn" aria-label="Remove item" title="Remove item">
                                                    &times;
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div id="emptyItemsMessage" class="alert alert-warning mt-3 mb-0 @(Model.Items.Count > 0 ? "d-none" : "")">
                            No receipt items are currently listed. Add an item manually if needed.
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-grid d-md-flex justify-content-md-end gap-2 mt-4">
                <a asp-controller="Receipt" asp-action="Details" asp-route-id="@Model.ReceiptId" class="btn btn-outline-secondary btn-lg">
                    Cancel
                </a>
                <button type="submit" class="btn btn-success btn-lg">
                    Save changes
                </button>
            </div>
        }
    </div>
</section>

<template id="itemRowTemplate">
    <tr class="receipt-item-row">
        <td data-label="Product">
            <input type="hidden" data-field="ItemId" value="" />
            <input type="hidden" data-field="ReceiptId" value="" />
            <input data-field="Name" class="form-control item-name" value="" />
        </td>
        <td data-label="Qty">
            <input data-field="Quantity" class="form-control item-quantity" value="1" />
        </td>
        <td data-label="Unit price">
            <input data-field="UnitPrice" class="form-control item-unit-price" value="0.00" />
        </td>
        <td data-label="Total">
            <input data-field="TotalPrice" class="form-control item-total-price" value="0.00" />
        </td>
        <td data-label="Category">
            <input data-field="Category" class="form-control item-category" value="Други" />
        </td>
        <td data-label="Action" class="text-end">
            <button type="button" class="btn btn-outline-danger btn-sm remove-item-btn" aria-label="Remove item" title="Remove item">
                &times;
            </button>
        </td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/receipt-result.js" asp-append-version="true"></script>
}
