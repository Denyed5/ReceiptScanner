@model ReceiptUploadModel

@{
    ViewData["Title"] = "Upload Receipt";
}

<section class="py-4 py-lg-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                    <div>
                        <h1 class="h2 fw-bold mb-2">Upload receipt</h1>
                        <p class="text-muted mb-0">
                            Take a receipt photo or upload an existing image, then scan it with OCR.
                        </p>
                    </div>
                </div>

                <form id="uploadForm" asp-controller="Receipt" asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="croppedImage" id="croppedImage" />
                    <input type="hidden" id="uploadInitialErrorMessage" value="@ViewBag.UploadErrorMessage" />

                    <div class="row g-4">
                        <div class="col-12 col-lg-7">
                            <div class="border rounded-3 p-3 p-md-4 h-100">
                                <label class="form-label fw-semibold">
                                    Receipt image
                                </label>

                                <div class="d-grid d-sm-flex gap-2 mb-3">
                                    <button class="btn btn-primary" type="button" id="takePhotoBtn">
                                        Take photo
                                    </button>

                                    <button class="btn btn-outline-primary" type="button" id="chooseFileBtn">
                                        Choose image
                                    </button>
                                </div>

                                <input name="File" id="cameraInput" class="visually-hidden" type="file" accept="image/*" capture="environment" />
                                <input name="File" id="receiptInput" class="visually-hidden" type="file" accept="image/*" />

                                <span asp-validation-for="File" class="text-danger small"></span>

                                <div class="mt-3 border rounded-3 bg-light overflow-hidden">
                                    <div class="crop-container d-flex align-items-center justify-content-center">
                                        <img id="image" class="img-fluid" alt="" />
                                        <div id="emptyPreview" class="text-muted text-center p-5">
                                            Take a photo or choose a receipt image to preview and crop it here.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-5">
                            <div class="border rounded-3 p-3 p-md-4 h-100">
                                <h2 class="h5 fw-semibold mb-3">OCR language</h2>

                                <div class="vstack gap-2">
                                    <label class="border rounded-3 p-3 d-flex gap-2">
                                        <input class="form-check-input mt-1" type="radio" name="Language" value="bul+eng" checked>
                                        <span>
                                            <span class="d-block fw-semibold">Bulgarian and English</span>
                                            <span class="d-block text-muted small">Best option for mixed receipts.</span>
                                        </span>
                                    </label>

                                    <label class="border rounded-3 p-3 d-flex gap-2">
                                        <input class="form-check-input mt-1" type="radio" name="Language" value="bul">
                                        <span>
                                            <span class="d-block fw-semibold">Bulgarian</span>
                                            <span class="d-block text-muted small">Use for Bulgarian-only receipts.</span>
                                        </span>
                                    </label>

                                    <label class="border rounded-3 p-3 d-flex gap-2">
                                        <input class="form-check-input mt-1" type="radio" name="Language" value="eng">
                                        <span>
                                            <span class="d-block fw-semibold">English</span>
                                            <span class="d-block text-muted small">Use for English-only receipts.</span>
                                        </span>
                                    </label>
                                </div>

                                <button class="btn btn-success btn-lg w-100 mt-4" id="scanBtn" type="button">
                                    Scan receipt
                                </button>

                                @if (ViewBag.Message != null)
                                {
                                    <div class="alert alert-info mt-3 mb-0">
                                        @ViewBag.Message
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="uploadErrorModal" tabindex="-1" aria-labelledby="uploadErrorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="uploadErrorModalLabel">Image upload error</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="uploadErrorMessage">
                Unsupported image format. Please upload a JPG, PNG, or BMP receipt image.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Choose another image</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/receipt-upload.js" asp-append-version="true"></script>
}
