@model List<ReceiptScanner.Models.ReceiptModel>

@{
    ViewData["Title"] = "История на касовите бележки";

    string sortBy = ViewBag.SortBy as string ?? "date";
    string sortDirection = ViewBag.SortDirection as string ?? "desc";

    string NextDirection(string column)
    {
        if (sortBy == column && sortDirection == "asc")
        {
            return "desc";
        }

        return "asc";
    }
}

<section class="py-4 py-lg-4">
    <div class="container">
        <div class="history-header mb-3">
            <div>
                <h1 class="mb-2">История на касовите бележки</h1>
                <p class="mb-0">
                    Преглеждай запазените си касови бележки и отвори всяка бележка, за да видиш продуктите в нея.
                </p>
            </div>

                <a asp-controller="Receipt" asp-action="Upload" class="btn btn-primary btn-lg">
                    Сканирай касова бележка
                </a>
        </div>

        @if (Model.Count == 0)
        {
            <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">

                <div class="d-flex flex-wrap gap-2 mb-3">

                    <a asp-action="History"
                       asp-route-period="week"
                       class="btn btn-primary">
                        Тази седмица
                    </a>

                    <a asp-action="History"
                       asp-route-period="month"
                       class="btn btn-primary">
                        Този месец
                    </a>

                    <a asp-action="History"
                       asp-route-period="30days"
                       class="btn btn-primary">
                        Последни 30 дни
                    </a>

                    <a asp-action="History"
                       asp-route-period="year"
                       class="btn btn-primary">
                        Тази година
                    </a>

                    <button class="btn btn-primary"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#filtersPanel">
                        Персонализиран период
                    </button>

                    <a asp-action="History"
                       class="btn btn-outline-secondary custom-btn">
                        Изчисти
                    </a>

                </div>

                <div class="collapse" id="filtersPanel">

                    <form method="get" asp-action="History">

                        <div class="row g-3 align-items-end">

                            <div class="col-md-4">
                                <label class="form-label">Начална дата</label>
                                <input type="date"
                                       name="startDate"
                                       value="@ViewBag.StartDate"
                                       class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Крайна дата</label>
                                <input type="date"
                                       name="endDate"
                                       value="@ViewBag.EndDate"
                                       class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <div class="d-flex gap-2">

                                    <button type="submit"
                                            class="btn btn-primary">
                                        Филтрирай
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <br>
                <div class="text-center">
                <h2 class="h4 fw-semibold mb-2">Няма запазени касови бележки</h2>
                <p class="text-muted mb-4">
                    Тук ще се появят запазените касови бележки, след като ги сканираш и потвърдиш.
                </p>

                <a asp-controller="Receipt" asp-action="Upload" class="btn btn-primary btn-lg">
                    Сканирай първата си касова бележка
                </a>
                </div>
            </div>
        }
        else
        {
            <div class="border rounded-4 p-4 shadow-sm h-100 bg-white">

                <div class="d-flex flex-wrap gap-2 mb-3">

                    <a asp-action="History"
                       asp-route-period="week"
                       class="btn btn-primary">
                        Тази седмица
                    </a>

                    <a asp-action="History"
                       asp-route-period="month"
                       class="btn btn-primary">
                        Този месец
                    </a>

                    <a asp-action="History"
                       asp-route-period="30days"
                       class="btn btn-primary">
                        Последни 30 дни
                    </a>

                    <a asp-action="History"
                       asp-route-period="year"
                       class="btn btn-primary">
                        Тази година
                    </a>

                    <button class="btn btn-primary"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#filtersPanel">
                        Персонализиран период
                    </button>

                    <a asp-action="History"
                       class="btn btn-outline-secondary custom-btn">
                        Изчисти
                    </a>

                </div>

                <div class="collapse" id="filtersPanel">

                    <form method="get" asp-action="History">

                        <div class="row g-3 align-items-end">

                            <div class="col-md-4">
                                <label class="form-label">Начална дата</label>
                                <input type="date"
                                       name="startDate"
                                       value="@ViewBag.StartDate"
                                       class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Крайна дата</label>
                                <input type="date"
                                       name="endDate"
                                       value="@ViewBag.EndDate"
                                       class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <div class="d-flex gap-2">

                                    <button type="submit"
                                            class="btn btn-primary">
                                        Филтрирай
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <br>

                <div class="alert border text-center mb-4">
                    <strong>Избран период:</strong>
                    @ViewBag.PeriodTextHistory
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 70px;">№</th>

                                <th>Търговец</th>

                                <th>
                                    <a asp-controller="Receipt"
                                       asp-action="History"
                                       asp-route-sortBy="date"
                                       asp-route-sortDirection="@NextDirection("date")"
                                       asp-route-startDate="@ViewBag.StartDate"
                                       asp-route-endDate="@ViewBag.EndDate"
                                       class="link-dark text-decoration-none">
                                        Дата
                                        @if (sortBy == "date")
                                        {
                                            <i class="bi @(sortDirection == "asc"
                                                               ? "bi-sort-up"
                                                               : "bi-sort-down")"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-arrow-down-up"></i>
                                        }
                                    </a>
                                </th>

                                <th class="text-end">
                                    <a asp-controller="Receipt"
                                       asp-action="History"
                                       asp-route-sortBy="total"
                                       asp-route-sortDirection="@NextDirection("total")"
                                       asp-route-startDate="@ViewBag.StartDate"
                                       asp-route-endDate="@ViewBag.EndDate"
                                       class="link-dark text-decoration-none">
                                        Общо в лева

                                        @if (sortBy == "total")
                                        {
                                            <i class="bi @(sortDirection == "asc"
                                                               ? "bi-sort-up"
                                                               : "bi-sort-down")"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-arrow-down-up"></i>
                                        }
                                    </a>
                                </th>

                                <th class="text-end">
                                    <a asp-controller="Receipt"
                                       asp-action="History"
                                       asp-route-sortBy="total"
                                       asp-route-sortDirection="@NextDirection("total")"
                                       asp-route-startDate="@ViewBag.StartDate"
                                       asp-route-endDate="@ViewBag.EndDate"
                                       class="link-dark text-decoration-none">
                                        Общо в евро

                                        @if (sortBy == "total")
                                        {
                                            <i class="bi @(sortDirection == "asc"
                                                               ? "bi-sort-up"
                                                               : "bi-sort-down")"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-arrow-down-up"></i>
                                        }
                                    </a>
                                </th>

                                <th class="text-end">Действие</th>
                            </tr>
                        </thead>

                        <tbody>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                var receipt = Model[i];

                                <tr>
                                    <td>@(i + 1)</td>

                                    <td>@(receipt.VendorName ?? "Неизвестен търговец")</td>

                                    <td>@(receipt.Date?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>

                                    <td class="text-end">
                                        @((receipt.TotalBGN ?? 0).ToString("0.00")) лв.
                                    </td>

                                    <td class="text-end">
                                        @((receipt.TotalEUR ?? 0).ToString("0.00")) €
                                    </td>

                                    <td class="text-end">
                                        <div class="receipt-action-buttons">
                                            <a asp-controller="Receipt"
                                               asp-action="Details"
                                               asp-route-id="@receipt.ReceiptId"
                                               class="btn btn-outline-primary btn-sm">
                                                Детайли
                                            </a>

                                            <a asp-controller="Receipt"
                                               asp-action="Edit"
                                               asp-route-id="@receipt.ReceiptId"
                                               class="btn btn-outline-secondary btn-sm">
                                                Редактирай
                                            </a>

                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteReceiptModal"
                                                    data-receipt-id="@receipt.ReceiptId"
                                                    data-receipt-name="@(receipt.VendorName ?? "Неизвестен търговец")">
                                                Изтрий
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>

<div class="modal fade"
     id="deleteReceiptModal"
     tabindex="-1"
     aria-labelledby="deleteReceiptModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h2 class="modal-title h5" id="deleteReceiptModalLabel">
                    Изтриване на касова бележка
                </h2>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Затвори">
                </button>
            </div>

            <div class="modal-body">
                Сигурни ли сте, че искате да изтриете
                <strong id="deleteReceiptName">тази касова бележка</strong>?
                Това действие не може да бъде отменено.
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Отказ
                </button>

                <form asp-controller="Receipt"
                      asp-action="Delete"
                      method="post"
                      class="m-0">

                    @Html.AntiForgeryToken()

                    <input type="hidden" name="id" id="deleteReceiptId" />

                    <button type="submit" class="btn btn-danger">
                        Изтрий касовата бележка
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/receipt-history.js" asp-append-version="true"></script>
}