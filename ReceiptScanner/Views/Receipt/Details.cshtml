@model ReceiptScanner.Models.ReceiptModel

@{
    ViewData["Title"] = "Receipt Details";
}

<section class="py-4 py-lg-5">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 fw-bold mb-2">Receipt details</h1>
                <p class="text-muted mb-0">
                    Review the saved receipt summary and extracted items.
                </p>
            </div>

            <div class="d-grid d-md-flex gap-2">
                <a asp-controller="Receipt" asp-action="Edit" asp-route-id="@Model.ReceiptId" class="btn btn-primary btn-lg">
                    Edit receipt
                </a>
                <a asp-controller="Receipt" asp-action="History" class="btn btn-outline-secondary btn-lg">
                    Back to history
                </a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-4">
                <div class="border rounded-3 p-3 p-md-4 h-100">
                    <h2 class="h5 fw-semibold mb-3">Summary</h2>

                    <div class="vstack gap-3">
                        <div>
                            <div class="text-muted small">Vendor</div>
                            <div class="fw-semibold">@(Model.VendorName ?? "Unknown vendor")</div>
                        </div>

                        <div>
                            <div class="text-muted small">Date</div>
                            <div class="fw-semibold">@(Model.Date?.ToString("dd.MM.yyyy HH:mm") ?? "-")</div>
                        </div>

                        <div>
                            <div class="text-muted small">Total BGN</div>
                            <div class="fw-semibold">@((Model.TotalBGN ?? 0).ToString("0.00")) лв.</div>
                        </div>

                        <div>
                            <div class="text-muted small">Total EUR</div>
                            <div class="fw-semibold">@((Model.TotalEUR ?? 0).ToString("0.00")) EUR</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                <div class="border rounded-3 p-3 p-md-4 h-100">
                    <h2 class="h5 fw-semibold mb-3">Items</h2>

                    @if (Model.Items.Count == 0)
                    {
                        <p class="text-muted mb-0">No items were saved for this receipt.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-end">Unit price</th>
                                        <th class="text-end">Total</th>
                                        <th>Category</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td class="text-end">@item.Quantity.ToString("0.##")</td>
                                            <td class="text-end">@item.UnitPrice.ToString("0.00")</td>
                                            <td class="text-end">@item.TotalPrice.ToString("0.00")</td>
                                            <td>@item.Category</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12">
                <div class="border rounded-3 p-3 p-md-4">
                    <h2 class="h5 fw-semibold mb-3">Raw OCR text</h2>

                    @if (!string.IsNullOrWhiteSpace(Model.RawText))
                    {
                        <pre class="bg-light border rounded-3 p-3 small mb-0 white-space-pre-wrap">@Model.RawText</pre>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No raw OCR text was saved for this receipt.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
