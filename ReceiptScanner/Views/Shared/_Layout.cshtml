<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReceiptScanner</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ReceiptScanner.styles.css" asp-append-version="true" />
    <link href="~/lib/cropper/cropper.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    ReceiptScanner
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Dashboard">
                                    Табло
                                </a>
                            }
                            else
                            {
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                    Начална страница
                                </a>
                            }
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Receipt" asp-action="Upload">
                                Качи бележка
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Receipt" asp-action="History">
                                    История
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-area=""
                                   asp-controller="Dashboard"
                                   asp-action="Analytics">
                                    Анализи
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex flex-column flex-lg-row gap-2 align-items-lg-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-muted small">
                                @User.Identity.Name
                            </span>

                            <form class="m-0" asp-area="Identity" asp-page="/Account/Logout"
                                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                    Изход
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">
                                Вход
                            </a>

                            <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Register">
                                Регистрация
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top py-3 text-muted">
        <div class="container d-flex flex-column flex-sm-row justify-content-between gap-2 small">
            <span>&copy; 2026 - ReceiptScanner</span>
            <a class="text-muted" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/cropper/cropper.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
