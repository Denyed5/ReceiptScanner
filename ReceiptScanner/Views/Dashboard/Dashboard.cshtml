@model ReceiptScanner.Models.DashboardModel

@{
    ViewData["Title"] = "Табло";
}
<section class="py-4 py-lg-4">
    <div class="container">
        <div class="dashboard-header mb-3">
            <div>
                <h1 class="mb-2">Табло</h1>
                <p class="mb-0">
                    Преглед на запазените касови бележки и разходи.
                </p>
            </div>

            <a asp-controller="Receipt"
               asp-action="Upload"
               class="btn btn-primary btn-lg">
                Добави бележка
            </a>
        </div>

        <div class="row g-3 mb-4">

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="dashboard-stat-card stat-total">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="text-muted fw-bold small">
                            Общо разходи
                        </div>
                    </div>

                    <div class="stat-value">
                        @Model.TotalSpentEUR.ToString("0.00") €
                    </div>

                    <div class="stat-secondary">
                        @Model.TotalSpentBGN.ToString("0.00") лв.
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="dashboard-stat-card stat-total">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="text-muted fw-bold small">
                            Разходи за текущия месец
                        </div>
                    </div>

                    <div class="stat-value">
                        @Model.ThisMonthSpentEUR.ToString("0.00") €
                    </div>

                    <div class="stat-secondary">
                        @Model.ThisMonthSpentBGN.ToString("0.00") лв.
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="dashboard-stat-card stat-total">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="text-muted fw-bold small">
                            Запазени касови бележки
                        </div>
                    </div>

                    <div class="stat-value">
                        @Model.ReceiptCount
                    </div>

                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="dashboard-stat-card stat-total">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="text-muted fw-bold small">
                            Най-честа категория
                        </div>
                    </div>

                    <div class="stat-value">
                        @Model.TopCategory
                    </div>

                </div>
            </div>

        </div>

        @if (Model.ReceiptCount == 0)
        {
            <div class="border rounded-3 p-4 p-md-5 text-center">
                <h2 class="h4 fw-semibold mb-2">Все още няма касови бележки</h2>
                <p class="text-muted mb-4">
                    Сканирай първата си касова бележка, за да започнеш да изграждаш историята на разходите си.
                </p>
                <a asp-controller="Receipt" asp-action="Upload" class="btn btn-primary btn-lg">
                    Сканирай първата си касова бележка
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-12 col-lg-7">
                    <div class="dashboard-card h-100">
                        <h2 class="h5 fw-semibold mb-3">Последни касови бележки</h2>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Търговец</th>
                                        <th>Дата</th>
                                        <th class="text-end">Общо</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var receipt in Model.RecentReceipts)
                                    {
                                        <tr>
                                            <td>@(receipt.VendorName ?? "Неизвестен")</td>
                                            <td>@(receipt.Date?.ToString("dd.MM.yyyy") ?? "-")</td>
                                            <td class="text-end">@((receipt.TotalEUR ?? 0).ToString("0.00")) €</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-5">
                    <div class="dashboard-card h-100">
                        <h2 class="h5 fw-semibold mb-3">Категории</h2>

                        @if (Model.CategoryTotals.Count == 0)
                        {
                            <p class="text-muted mb-0">Все още няма налични данни за категории.</p>
                        }
                        else
                        {
                            <div class="vstack gap-3">
                                @foreach (var category in Model.CategoryTotals.Take(5))
                                {
                                    var percent = Model.TotalSpentBGN > 0
                                        ? Math.Round((category.Value / Model.TotalSpentBGN) * 100)
                                        : 0;

                                    <div>
                                        <div class="d-flex justify-content-between gap-3 mb-1">
                                            <span>@category.Key</span>
                                            <span class="text-muted">@category.Value.ToString("0.00") €</span>
                                        </div>
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar" style="width: @percent%;"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</section>